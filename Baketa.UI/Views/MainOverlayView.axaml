<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Baketa.UI.ViewModels"
        xmlns:local="using:Baketa.UI.Extensions"
        mc:Ignorable="d" d:DesignWidth="110" d:DesignHeight="600"
        x:Class="Baketa.UI.Views.MainOverlayView"
        x:DataType="vm:MainOverlayViewModel"
        Title="Baketa Overlay"
        SizeToContent="WidthAndHeight"
        MaxWidth="300"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        CanResize="False"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="0">

  <!-- [Issue #245] Window.Resourcesを削除し、OverlayDesignTokens.axamlのDynamicResourceを使用 -->

  <Window.Styles>
    <!-- Window自体の枠線・背景を透明に -->
    <Style Selector="Window">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <!-- Avalonia内部テンプレートのボーダー除去 -->
    <Style Selector="Window /template/ Border#PART_TransparencyFallback">
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Window /template/ Border">
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- メニュー項目スタイル -->
    <!-- 🔥 [ISSUE#171] 多言語対応: Width固定値 → MinWidth に変更（テキスト長に応じて自動調整） -->
    <!-- [Issue #245] StaticResource → DynamicResource（テーマ対応） -->
    <Style Selector="Button.menu-item">
      <Setter Property="Background" Value="{DynamicResource OverlayButtonBackgroundBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Margin" Value="4,2"/>
      <Setter Property="MinWidth" Value="50"/>
    </Style>

    <Style Selector="Button.menu-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource OverlayButtonHoverBrush}"/>
    </Style>

    <Style Selector="Button.menu-item:pressed">
      <Setter Property="Background" Value="{DynamicResource OverlayButtonPressedBrush}"/>
    </Style>

    <!-- ステータス表示スタイル（未使用 - Status削除済み） -->
    <Style Selector="Border.status-item">
      <Setter Property="Background" Value="{DynamicResource OverlayButtonBackgroundBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Margin" Value="4,2"/>
      <Setter Property="MinWidth" Value="50"/>
    </Style>
    
    <!-- 最小化ボタンスタイル -->
    <!-- 🔥 [ISSUE#171] 多言語対応: Width固定値 → MinWidth に変更 -->
    <Style Selector="Button.minimize-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="MinWidth" Value="36"/>
      <Setter Property="Margin" Value="2,4"/>
    </Style>

    <Style Selector="Button.minimize-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource OverlayButtonHoverBrush}"/>
    </Style>

    <!-- 非アクティブボタンスタイル - 背景色なし、アイコンとテキストのみ薄いグレー -->
    <Style Selector="Button.menu-item:disabled">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="Button.menu-item:disabled PathIcon">
      <Setter Property="Foreground" Value="{DynamicResource OverlayIconDisabledBrush}"/>
    </Style>

    <Style Selector="Button.menu-item:disabled TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource OverlayIconDisabledBrush}"/>
    </Style>

    <!-- 非アクティブ状態でホバー効果も無効化 -->
    <Style Selector="Button.menu-item:disabled:pointerover">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ドラッグハンドルスタイル (#246) -->
    <Style Selector="Border.drag-handle">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Cursor" Value="SizeAll"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Padding" Value="4"/>
    </Style>

    <Style Selector="Border.drag-handle:pointerover">
      <Setter Property="Background" Value="{DynamicResource OverlayButtonHoverBrush}"/>
    </Style>
  </Window.Styles>

  <!-- メインコンテナ -->
  <Grid ColumnDefinitions="Auto,Auto">

  <!-- メインオーバーレイ: 縦型アイコン+テキスト構成 -->
  <!-- [Issue #245] DynamicResourceでテーマ対応 -->
  <Border Name="MainOverlayBorder"
          Grid.Column="0"
          Background="{DynamicResource OverlayBackgroundBrush}"
          BorderBrush="{DynamicResource OverlayBorderBrush}"
          BorderThickness="1"
          CornerRadius="8"
          BoxShadow="0 4 12 0 #40000000"
          Padding="4"
          ClipToBounds="True"
          IsVisible="{Binding !IsCollapsed}">

      <StackPanel Orientation="Vertical" Spacing="2">

      <!-- ドラッグハンドル (#246) -->
      <Border Classes="drag-handle"
              Name="DragHandle"
              CornerRadius="4"
              Margin="4,4,4,2"
              Height="20"
              ToolTip.Tip="{local:Localize MainOverlay_DragToMove}"
              PointerPressed="OnDragHandlePointerPressed">
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
          <!-- 6ドットグリップパターン (⋮⋮) -->
          <StackPanel Orientation="Horizontal" Spacing="3">
            <StackPanel Orientation="Vertical" Spacing="2">
              <Ellipse Width="3" Height="3" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
              <Ellipse Width="3" Height="3" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
              <Ellipse Width="3" Height="3" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Spacing="2">
              <Ellipse Width="3" Height="3" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
              <Ellipse Width="3" Height="3" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
              <Ellipse Width="3" Height="3" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 🔥 [Issue #300] VRAM警告インジケーター -->
      <Border IsVisible="{Binding HasMemoryWarning}"
              Background="#FFFFA500"
              CornerRadius="4"
              Padding="4,2"
              Margin="4,2"
              HorizontalAlignment="Center"
              ToolTip.Tip="GPUメモリ使用率が高くなっています">
        <TextBlock Text="⚠️ メモリ警告"
                   FontSize="9"
                   Foreground="Black"
                   HorizontalAlignment="Center"
                   FontWeight="Bold"/>
      </Border>

      <!-- 最小化ボタン - ウィンドウ選択後のみ表示 -->
      <!-- 🔥 [ISSUE#171] UI改善: Minテキスト削除、アイコンサイズをexpandと統一（16px） -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応） -->
      <Button Classes="minimize-button"
              Command="{Binding FoldCommand}"
              ToolTip.Tip="{local:Localize MainOverlay_Minimize}"
              AutomationProperties.Name="最小化ボタン"
              IsVisible="{Binding IsWindowSelected}">
        <PathIcon Width="16" Height="16"
                  Data="{StaticResource ChevronUpIcon}"
                  Foreground="{DynamicResource OverlayIconBrush}"/>
      </Button>
      
      <!-- ウィンドウ選択ボタン - 常に表示 -->
      <!-- 🔥 [ISSUE#171] UI改善: Select → Target に変更 -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応） -->
      <Button Classes="menu-item"
              Command="{Binding SelectWindowCommand}"
              ToolTip.Tip="{local:Localize MainOverlay_SelectWindow}"
              Name="SelectWindowButton"
              IsEnabled="{Binding IsSelectWindowEnabled}"
              AutomationProperties.Name="翻訳対象ウィンドウを選択">
        <StackPanel Orientation="Vertical" Spacing="4">
          <PathIcon Width="18" Height="18"
                    Data="{StaticResource TargetIcon}"
                    Foreground="{DynamicResource OverlayIconBrush}"/>
          <TextBlock Text="{local:Localize MainOverlay_Target}"
                     FontSize="10"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="{DynamicResource OverlayTextBrush}"
                     IsVisible="{Binding !IsCollapsed}"/>
        </StackPanel>
      </Button>
      
      <!-- [Issue #357] Shot翻訳ボタン - ウィンドウ選択後のみ表示 (Live翻訳より上に配置) -->
      <!-- 🔥 [ISSUE#171] UI改善: Shot → Shot翻訳 に変更、状態による表示制御 -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応、状態切替） -->
      <!-- [Issue #318] EXモード時に⚡バッジ表示 -->
      <!-- [Issue #357] アクティブ時はクリアアイコン(DismissIcon)に変更 -->
      <Button Classes="translation-mode-button"
              Classes.pulsing="{Binding IsSingleshotActive}"
              IsEnabled="{Binding IsSingleshotEnabled}"
              IsVisible="{Binding IsWindowSelected}"
              Command="{Binding ExecuteSingleshotCommand}"
              ToolTip.Tip="{Binding SingleshotButtonTooltip}"
              Name="SingleshotButton">
        <StackPanel Orientation="Vertical" Spacing="4">
          <Panel Width="20" Height="20">
            <!-- 通常状態: カメラアイコン -->
            <PathIcon Data="{StaticResource CameraIcon}"
                      Foreground="{DynamicResource OverlayIconBrush}"
                      IsVisible="{Binding !IsSingleshotActive}"/>
            <!-- [Issue #357] アクティブ状態: リセットアイコン（赤）→ 押すとリセットされることを視覚的に示す -->
            <PathIcon Data="{StaticResource RefreshIcon}"
                      Foreground="{DynamicResource OverlayStatusErrorBrush}"
                      IsVisible="{Binding IsSingleshotActive}"/>
            <!-- [Issue #318] EXモードバッジ -->
            <Border Background="#CCffffff" CornerRadius="8" Width="16" Height="16"
                    BorderBrush="#999999" BorderThickness="1"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-5,-7,0"
                    IsVisible="{Binding IsEXModeEnabled}">
              <PathIcon Data="{StaticResource LightningIcon}"
                        Width="10" Height="10"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Foreground="#FFB800"/>
            </Border>
          </Panel>
          <TextBlock Text="{Binding SingleshotButtonText}"
                     FontSize="10"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="{DynamicResource OverlayTextBrush}"
                     IsVisible="{Binding !IsCollapsed}"/>
        </StackPanel>
      </Button>

      <!-- Live翻訳ボタン - ウィンドウ選択後のみ表示 -->
      <!-- 🔥 [ISSUE#171] UI改善: Start → Live翻訳 に変更、状態による表示制御 -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応、状態切替） -->
      <!-- [Issue #318] EXモード時に⚡バッジ表示 -->
      <!-- [Issue #357] アクティブ時はStopアイコンと「停止」テキストに動的変更 -->
      <Button Classes="translation-mode-button"
              Classes.pulsing="{Binding IsLiveActive}"
              IsEnabled="{Binding IsLiveEnabled}"
              IsVisible="{Binding IsWindowSelected}"
              Command="{Binding StartStopCommand}"
              ToolTip.Tip="{Binding StartButtonTooltip}"
              Name="StartStopButton"
              PointerPressed="StartStopButton_OnPointerPressed">
        <StackPanel Orientation="Vertical" Spacing="4">
          <Panel Width="20" Height="20">
            <!-- 通常状態: ビデオカメラアイコン -->
            <PathIcon Data="{StaticResource VideoIcon}"
                      Foreground="{DynamicResource OverlayIconBrush}"
                      IsVisible="{Binding !IsLiveActive}"/>
            <!-- [Issue #357] アクティブ状態: 停止アイコン（赤） -->
            <PathIcon Data="{StaticResource StopIcon}"
                      Foreground="{DynamicResource OverlayStatusErrorBrush}"
                      IsVisible="{Binding IsLiveActive}"/>
            <!-- [Issue #318] EXモードバッジ -->
            <Border Background="#CCffffff" CornerRadius="8" Width="16" Height="16"
                    BorderBrush="#999999" BorderThickness="1"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-5,-7,0"
                    IsVisible="{Binding IsEXModeEnabled}">
              <PathIcon Data="{StaticResource LightningIcon}"
                        Width="10" Height="10"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Foreground="#FFB800"/>
            </Border>
          </Panel>
          <TextBlock Text="{Binding LiveButtonText}"
                     FontSize="10"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="{DynamicResource OverlayTextBrush}"
                     IsVisible="{Binding !IsCollapsed}"/>
        </StackPanel>
      </Button>

      <!-- ローディングインジケーター -->
      <Border Classes="status-item" IsVisible="{Binding IsLoading}">
        <StackPanel Orientation="Vertical" Spacing="4">
          <Ellipse Width="16" Height="16"
                   Fill="{DynamicResource OverlayStatusProcessingBrush}"
                   Opacity="0.8"/>
          <TextBlock Text="{local:Localize MainOverlay_Preparing}"
                     FontSize="9"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource OverlayStatusProcessingBrush}"/>
        </StackPanel>
      </Border>
      
      <!-- 翻訳表示切り替えボタン - ウィンドウ選択後のみ表示 -->
      <!-- 🔥 [ISSUE#171] UI改善: Show → 翻訳表示 に変更、状態による表示制御 -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応） -->
      <Button Classes="menu-item"
              Command="{Binding ShowHideCommand}"
              IsEnabled="{Binding ShowHideEnabled}"
              IsVisible="{Binding IsWindowSelected}"
              ToolTip.Tip="{local:Localize MainOverlay_ShowHideTranslation}">
        <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <PathIcon Width="18" Height="18"
                      Data="{StaticResource ViewIcon}"
                      Foreground="{DynamicResource OverlayIconBrush}"/>
            <Ellipse Width="8" Height="8"
                     Fill="{DynamicResource OverlayStatusActiveBrush}"
                     Margin="2,0,0,0"
                     IsVisible="{Binding IsTranslationActive}"/>
          </StackPanel>
          <TextBlock Text="{local:Localize MainOverlay_ShowTranslation}"
                     FontSize="10"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource OverlayTextBrush}"
                     IsVisible="{Binding !IsCollapsed}"/>
        </StackPanel>
      </Button>
      
      <!-- 設定ボタン - 常に表示 -->
      <!-- 🔥 [ISSUE#171] UI改善: Set → 設定 に変更 -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応） -->
      <Button Classes="menu-item"
              Command="{Binding SettingsCommand}"
              IsEnabled="{Binding SettingsEnabled}"
              ToolTip.Tip="{local:Localize MainOverlay_Settings}">
        <StackPanel Orientation="Vertical" Spacing="4">
          <PathIcon Width="18" Height="18"
                    Data="{StaticResource SettingsIcon}"
                    Foreground="{DynamicResource OverlayIconBrush}"/>
          <TextBlock Text="{local:Localize MainOverlay_Settings}"
                     FontSize="10"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource OverlayTextBrush}"
                     IsVisible="{Binding !IsCollapsed}"/>
        </StackPanel>
      </Button>
      
      <!-- 区切り線 -->
      <Rectangle Height="1"
                 Fill="{DynamicResource OverlayBorderBrush}"
                 Margin="8,4"
                 Opacity="0.5"/>

      <!-- 終了ボタン - 常に表示 -->
      <!-- 🔥 [ISSUE#171] UI改善: Exit テキストは展開時のみ表示 -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応） -->
      <Button Classes="menu-item"
              Command="{Binding ExitCommand}"
              ToolTip.Tip="{local:Localize MainOverlay_Exit}"
              Click="OnExitButtonClick">
        <StackPanel Orientation="Vertical" Spacing="4">
          <PathIcon Width="18" Height="18"
                    Data="{StaticResource ExitIcon}"
                    Foreground="{DynamicResource OverlayIconBrush}"/>
          <TextBlock Text="{local:Localize MainOverlay_Exit}"
                     FontSize="10"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource OverlayTextBrush}"
                     IsVisible="{Binding !IsCollapsed}"/>
        </StackPanel>
      </Button>

    </StackPanel>
  </Border>

  <!-- [Issue #449] 展開タブ + サブパネル -->
  <Panel Grid.Column="1"
         VerticalAlignment="Center"
         IsVisible="{Binding IsWindowSelected}"
         Margin="-2,0,0,0">

    <!-- 展開タブ（▶） - 閉じた時のみ表示 -->
    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            BorderBrush="{DynamicResource OverlayBorderBrush}"
            BorderThickness="0,1,1,1"
            CornerRadius="0,6,6,0"
            IsVisible="{Binding !IsRegionPanelOpen}">
      <Button Command="{Binding ToggleRegionPanelCommand}"
              Background="Transparent"
              BorderThickness="0"
              Padding="5,16"
              Cursor="Hand"
              ToolTip.Tip="OCR対象領域設定">
        <Panel>
          <PathIcon Width="10" Height="10"
                    Data="{StaticResource ChevronDownIcon}"
                    Foreground="{DynamicResource OverlayIconBrush}">
            <PathIcon.RenderTransform>
              <RotateTransform Angle="-90"/>
            </PathIcon.RenderTransform>
          </PathIcon>
          <Ellipse Width="5" Height="5"
                   Fill="{DynamicResource OverlayStatusActiveBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,-4"
                   IsVisible="{Binding IsRegionSelected}"/>
        </Panel>
      </Button>
    </Border>

    <!-- OCR領域サブパネル（展開時） -->
    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            BorderBrush="{DynamicResource OverlayBorderBrush}"
            BorderThickness="0,1,1,1"
            CornerRadius="0,8,8,0"
            Padding="6"
            IsVisible="{Binding IsRegionPanelOpen}">
      <StackPanel Orientation="Horizontal" Spacing="2">
        <!-- 全画面・領域選択（縦並び） -->
        <StackPanel Spacing="4">
          <!-- 全画面ボタン -->
          <Button Command="{Binding SetFullScreenModeCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4"
                  Cursor="Hand"
                  HorizontalAlignment="Center"
                  HorizontalContentAlignment="Center">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <Panel Width="16" Height="16" HorizontalAlignment="Center">
                <Path Data="M1,1 L21,1 L21,21 L1,21 Z M1,6 L21,6"
                      Stroke="{DynamicResource OverlayIconBrush}"
                      StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"
                      IsVisible="{Binding IsRegionSelected}"/>
                <Path Data="M1,1 L21,1 L21,21 L1,21 Z M1,6 L21,6"
                      Stroke="{DynamicResource OverlayStatusActiveBrush}"
                      StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"
                      IsVisible="{Binding !IsRegionSelected}"/>
              </Panel>
              <TextBlock Text="{local:Localize MainOverlay_FullOcr}"
                         FontSize="9"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Foreground="{DynamicResource OverlayTextBrush}"
                         IsVisible="{Binding !IsCollapsed}"/>
            </StackPanel>
          </Button>

          <!-- 領域選択ボタン -->
          <Button Command="{Binding SelectRegionCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4"
                  Cursor="Hand"
                  HorizontalAlignment="Center"
                  HorizontalContentAlignment="Center">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <Panel Width="16" Height="16" HorizontalAlignment="Center">
                <Path Data="M3,3 L19,3 L19,19 L3,19 Z"
                      Stroke="{DynamicResource OverlayIconBrush}"
                      StrokeThickness="1.5" StrokeDashArray="3,2"
                      StrokeLineCap="Round" Fill="Transparent" Stretch="Uniform"
                      IsVisible="{Binding !IsRegionSelected}"/>
                <Path Data="M3,3 L19,3 L19,19 L3,19 Z"
                      Stroke="{DynamicResource OverlayStatusActiveBrush}"
                      StrokeThickness="1.5" StrokeDashArray="3,2"
                      StrokeLineCap="Round" Fill="Transparent" Stretch="Uniform"
                      IsVisible="{Binding IsRegionSelected}"/>
              </Panel>
              <TextBlock Text="{local:Localize MainOverlay_RegionOcr}"
                         FontSize="9"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Foreground="{DynamicResource OverlayTextBrush}"
                         IsVisible="{Binding !IsCollapsed}"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- 閉じるボタン（◀）- 右側配置 -->
        <Button Command="{Binding ToggleRegionPanelCommand}"
                Background="Transparent"
                BorderThickness="0"
                Padding="3,12"
                Cursor="Hand"
                VerticalAlignment="Center">
          <PathIcon Width="10" Height="10"
                    Data="{StaticResource ChevronDownIcon}"
                    Foreground="{DynamicResource OverlayIconBrush}">
            <PathIcon.RenderTransform>
              <RotateTransform Angle="90"/>
            </PathIcon.RenderTransform>
          </PathIcon>
        </Button>
      </StackPanel>
    </Border>
  </Panel>

  <!-- 最小化状態 -->
  <!-- 🔥 [ISSUE#171] UI改善: Live翻訳、Shot翻訳、翻訳表示ボタン追加（アイコンのみ） -->
  <!-- Height削除: ウィンドウ選択状態に応じて自動調整 -->
  <Border Name="CollapsedOverlayBorder"
          Width="40"
          Background="{DynamicResource OverlayBackgroundBrush}"
          BorderBrush="{DynamicResource OverlayBorderBrush}"
          BorderThickness="1"
          CornerRadius="8"
          BoxShadow="0 2 8 0 #40000000"
          ClipToBounds="True"
          IsVisible="{Binding IsCollapsed}">

    <StackPanel Orientation="Vertical" Spacing="0">
      <!-- ドラッグハンドル（縮小時） (#246) -->
      <Border Classes="drag-handle"
              Name="CollapsedDragHandle"
              CornerRadius="4"
              Margin="2,2,2,0"
              Height="16"
              ToolTip.Tip="{local:Localize MainOverlay_DragToMove}"
              PointerPressed="OnDragHandlePointerPressed">
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
          <!-- 6ドットグリップパターン (⋮⋮) - 縮小版 -->
          <StackPanel Orientation="Horizontal" Spacing="2">
            <StackPanel Orientation="Vertical" Spacing="1">
              <Ellipse Width="2" Height="2" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
              <Ellipse Width="2" Height="2" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
              <Ellipse Width="2" Height="2" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Spacing="1">
              <Ellipse Width="2" Height="2" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
              <Ellipse Width="2" Height="2" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
              <Ellipse Width="2" Height="2" Fill="{DynamicResource OverlayIconBrush}" Opacity="0.5"/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 🔥 [Issue #300] VRAM警告インジケーター（縮小時） -->
      <Border IsVisible="{Binding HasMemoryWarning}"
              Background="#FFFFA500"
              CornerRadius="4"
              Width="36"
              Height="20"
              Margin="2,2"
              ToolTip.Tip="GPUメモリ使用率が高くなっています">
        <TextBlock Text="⚠️"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Border>

      <!-- 展開ボタン -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応） -->
      <Button Classes="minimize-button"
              Command="{Binding FoldCommand}"
              ToolTip.Tip="{local:Localize MainOverlay_Expand}"
              Background="Transparent"
              BorderThickness="0"
              Width="36"
              Height="36"
              Margin="2">
        <PathIcon Width="16" Height="16"
                  Data="{StaticResource ExpandIcon}"
                  Foreground="{DynamicResource OverlayIconBrush}"/>
      </Button>

      <!-- [Issue #357] Shot翻訳ボタン（縮小時） - ウィンドウ選択後のみ表示 (Live翻訳より上に配置) -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応、状態切替） -->
      <!-- [Issue #318] EXモード時に⚡バッジ表示 -->
      <!-- [Issue #357] アクティブ時はクリアアイコン(DismissIcon)に変更 -->
      <Button Classes="minimize-button"
              Command="{Binding ExecuteSingleshotCommand}"
              ToolTip.Tip="{Binding SingleshotButtonTooltip}"
              IsEnabled="{Binding IsSingleshotEnabled}"
              IsVisible="{Binding IsWindowSelected}"
              Background="Transparent"
              BorderThickness="0"
              Width="36"
              Height="36"
              Margin="2">
        <Panel Width="16" Height="16">
          <PathIcon Data="{StaticResource CameraIcon}"
                    Foreground="{DynamicResource OverlayIconBrush}"
                    IsVisible="{Binding !IsSingleshotActive}"/>
          <!-- [Issue #357] アクティブ状態: リセットアイコン（赤） -->
          <PathIcon Data="{StaticResource RefreshIcon}"
                    Foreground="{DynamicResource OverlayStatusErrorBrush}"
                    IsVisible="{Binding IsSingleshotActive}"/>
          <!-- [Issue #318] EXモードバッジ -->
          <Border Background="#CCffffff" CornerRadius="7" Width="14" Height="14"
                  BorderBrush="#999999" BorderThickness="1"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,-3,-5,0"
                  IsVisible="{Binding IsEXModeEnabled}">
            <PathIcon Data="{StaticResource LightningIcon}"
                      Width="8" Height="8"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Foreground="#FFB800"/>
          </Border>
        </Panel>
      </Button>

      <!-- Live翻訳ボタン（縮小時） - ウィンドウ選択後のみ表示 -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応、状態切替） -->
      <!-- [Issue #318] EXモード時に⚡バッジ表示 -->
      <!-- [Issue #357] アクティブ時はStopアイコンに動的変更 -->
      <Button Classes="minimize-button"
              Command="{Binding StartStopCommand}"
              ToolTip.Tip="{Binding StartButtonTooltip}"
              IsEnabled="{Binding IsLiveEnabled}"
              IsVisible="{Binding IsWindowSelected}"
              Background="Transparent"
              BorderThickness="0"
              Width="36"
              Height="36"
              Margin="2"
              PointerPressed="StartStopButton_OnPointerPressed">
        <Panel Width="16" Height="16">
          <PathIcon Data="{StaticResource VideoIcon}"
                    Foreground="{DynamicResource OverlayIconBrush}"
                    IsVisible="{Binding !IsLiveActive}"/>
          <!-- [Issue #357] アクティブ状態: 停止アイコン（赤） -->
          <PathIcon Data="{StaticResource StopIcon}"
                    Foreground="{DynamicResource OverlayStatusErrorBrush}"
                    IsVisible="{Binding IsLiveActive}"/>
          <!-- [Issue #318] EXモードバッジ -->
          <Border Background="#CCffffff" CornerRadius="7" Width="14" Height="14"
                  BorderBrush="#999999" BorderThickness="1"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,-3,-5,0"
                  IsVisible="{Binding IsEXModeEnabled}">
            <PathIcon Data="{StaticResource LightningIcon}"
                      Width="8" Height="8"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Foreground="#FFB800"/>
          </Border>
        </Panel>
      </Button>

      <!-- 翻訳表示ボタン（縮小時） - ウィンドウ選択後のみ表示 -->
      <!-- [Issue #245] PNG→PathIcon変換（テーマ対応） -->
      <Button Classes="minimize-button"
              Command="{Binding ShowHideCommand}"
              ToolTip.Tip="{local:Localize MainOverlay_ShowHideTranslation}"
              IsEnabled="{Binding ShowHideEnabled}"
              IsVisible="{Binding IsWindowSelected}"
              Background="Transparent"
              BorderThickness="0"
              Width="36"
              Height="36"
              Margin="2">
        <StackPanel>
          <PathIcon Width="16" Height="16"
                    Data="{StaticResource ViewIcon}"
                    Foreground="{DynamicResource OverlayIconBrush}"/>
          <Ellipse Width="6" Height="6"
                   Fill="{DynamicResource OverlayStatusActiveBrush}"
                   Margin="0,-2,0,0"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding IsTranslationActive}"/>
        </StackPanel>
      </Button>
    </StackPanel>
  </Border>

  </Grid>
</Window>